{
  "name": "decky-romm-sync",
  "version": "0.17.1",
  "description": "Decky Loader plugin to sync your RomM library to Steam as non-steam shortcuts",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "size": "size-limit"
  },
  "packageManager": "pnpm@10.29.3",
  "license": "GPL-3.0",
  "dependencies": {
    "@decky/api": "^1.1.3",
    "tslib": "^2.7.0"
  },
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.4",
    "@rollup/rollup-linux-x64-musl": "^4.60.4",
    "@size-limit/file": "^12.1.0",
    "@types/react": "^19.2.14",
    "react-icons": "^5.6.0",
    "rollup": "^4.60.4",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    },
    "overrides": {
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=3.0.0 <3.1.4": "3.1.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4"
    }
  }
}
